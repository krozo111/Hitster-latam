---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Hitster LATAM 🎵 - El Juego Musical Multijugador',
  description = 'Juega Hitster con tus amigos! Ordena canciones latinoamericanas en tu línea de tiempo. ¿Quién conoce mejor la música?'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0B0420" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="bg-pattern min-h-dvh">
  <slot />
</body>
</html>
